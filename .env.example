# --- Cartelera Planta — configuración ---
# Copiar este archivo como .env y ajustar los valores.

# Entorno
NODE_ENV=production
TZ=America/Argentina/Buenos_Aires

# Backend
PORT=3000
JWT_SECRET=change-me-to-a-long-random-string-at-least-32-chars
JWT_EXPIRES_IN=7d

# Base de datos (SQLite, path dentro del container)
DB_PATH=/data/cartelera.db

# Uploads
UPLOADS_DIR=/data/uploads
MAX_UPLOAD_MB=50

# Admin default (se crea solo si no existe ningún usuario)
ADMIN_EMAIL=admin@cartelera.local
ADMIN_PASSWORD=admin1234

# URL pública (la ven players y admins)
PUBLIC_URL=http://localhost:8080

# CORS — lista separada por coma, o '*' en dev
CORS_ORIGIN=*

# Logging
LOG_LEVEL=info

# Caddy
CADDY_DOMAIN=localhost
CADDY_EMAIL=internal@cartelera.local
